model Property {
    id String @id @default(uuid())

    title String

    description String

    rentPrice Decimal @db.Decimal(10, 2)

    bedrooms Int

    bathrooms Int

    area Float?

    address String

    city String

    division String

    latitude Float?

    longitude Float?

    availability PropertyStatus @default(AVAILABLE)

    isDeleted Boolean @default(false)

    landlordId String

    categoryId String

    createdAt DateTime @default(now())

    updatedAt DateTime @updatedAt

    landlord User @relation(fields: [landlordId], references: [id])

    category Category @relation(fields: [categoryId], references: [id])

    images PropertyImage[]

    rentalRequests RentalRequest[]

    reviews Review[]

    @@index([city])
    @@index([rentPrice])
    @@index([categoryId])
    @@map("properties")
}

model PropertyImage {
    id String @id @default(uuid())

    imageUrl String

    propertyId String

    property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())

    @@map("property_images")
}
